pipeline {
    agent any

    tools {
        maven 'Maven'
    }

    stages {
        stage('Build') {
            steps {
                dir('achat') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('achat') {
                    sh 'docker build -t mon-app:latest .'
                }
            }
        }

        stage('Docker Run') {
            steps {
                sh 'docker rm -f mon-app || true'
                sh 'docker run -d -p 8081:8080 --name mon-app mon-app:latest'
            }
        }

        stage('Test') {
            steps {
                dir('achat') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'achat/**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'achat/target/*.jar', fingerprint: true
            }
        }
    }

    post {
        success {
            echo 'Build réussi !'
        }
        failure {
            echo 'Build en échec.'
        }
    }
}