pipeline {
    agent any
    tools {
        maven 'Maven'
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                dir('achat') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir('achat') {
                    withSonarQubeEnv('SonarQube') {
                        sh 'mvn sonar:sonar'
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
        stage('Deploy to Nexus') {
            steps {
                dir('achat') {
                    sh 'mvn deploy -DskipTests -s /var/jenkins_home/.m2/settings.xml'
                }
            }
        }
        stage('Docker Build') {
            steps {
                dir('achat') {
                    sh 'docker build -t mon-app:latest .'
                }
            }
        }
        stage('Docker Run') {
            steps {
                sh '''
                    docker stop mon-app || true
                    docker rm mon-app || true
                    docker run -d -p 8080:8080 --name mon-app mon-app:latest
                '''
            }
        }
        stage('Test') {
            steps {
                dir('achat') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'achat/**/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'achat/target/*.jar', fingerprint: true
            }
        }
    }
    post {
        success {
            echo 'Build reussi !'
        }
        failure {
            echo 'Build en echec.'
        }
    }
}
